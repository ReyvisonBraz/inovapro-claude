# FinanceFlow OS - Environment Variables

# Server
PORT=3000

# Security (OBRIGATÓRIO ALTERAR EM PRODUÇÃO!)
# Gere uma string aleatória com pelo menos 32 caracteres
# Exemplo: openssl rand -base64 32
JWT_SECRET=sua-chave-secreta-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=8h

# Criptografia de senhas (10-12 recommended)
BCRYPT_ROUNDS=12

# CORS (Configure seu domínio em produção)
# Desenvolvimento: http://localhost:5173
# Produção: https://seudominio.com
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=10

# Body Parser Limit
BODY_LIMIT=5mb

# Database (futura migração PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Gemini AI (opcional - para análise técnica de OS)
GEMINI_API_KEY=

# Node Environment
NODE_ENV=development
