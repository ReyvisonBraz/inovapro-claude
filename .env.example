# =========================================================
# INOVA PRO — Variáveis de Ambiente
# =========================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# Legenda de obrigatoriedade:
#   [OBRIGATÓRIO]  — O app não funciona sem esse valor
#   [RECOMENDADO]  — Necessário para funcionalidades importantes
#   [OPCIONAL]     — Funcionalidades extras ou com fallback
# =========================================================

# ──────────────────────────────────────────────────────────
# FRONTEND (Vite — prefixo VITE_)
# ──────────────────────────────────────────────────────────

# [OBRIGATÓRIO] URL base da API backend.
#   → Usado em: src/lib/api.ts (Axios baseURL)
#   → Produção: URL do Cloud Run/Railway (ex: https://inovapro-production-32fa.up.railway.app)
#   → Local: http://localhost:3000 ou http://localhost:3001
VITE_API_URL=http://localhost:3000

# [OPCIONAL] URL do projeto Supabase (funcionalidade standby/futura).
#   → Usado em: src/lib/supabase-standby.ts (atualmente comentado)
#   → Onde pegar: Dashboard do Supabase → Settings → API → Project URL
#   → Ex: https://xyzproject.supabase.co
VITE_SUPABASE_URL=

# [OPCIONAL] Chave pública (anon) do Supabase.
#   → Usado em: src/lib/supabase-standby.ts (atualmente comentado)
#   → Onde pegar: Dashboard do Supabase → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────
# BACKEND — Servidor Express
# ──────────────────────────────────────────────────────────

# [OPCIONAL] Porta do servidor. Default: 3001 em dev, 8080 em Cloud Run.
#   → Usado em: server.ts
#   → Cloud Run injeta PORT=8080 automaticamente
#   → Railway/Render: geralmente 3000
PORT=3000

# [OBRIGATÓRIO] Segredo para assinar/verificar tokens JWT.
#   → Usado em: src/middleware/auth.ts, supabase/functions/login/index.ts
#   → Gerar com: openssl rand -hex 32
#   → ⚠️ Nunca commite o valor real! Em produção use Secret Manager.
JWT_SECRET=seu-segredo-aqui-minimo-32-caracteres

# [OBRIGATÓRIO] URL base do frontend para configuração CORS.
#   → Usado em: server.ts (allowedOrigins)
#   → Local: http://localhost:5173
#   → Produção Vercel: https://seu-app.vercel.app
#   → Aceita regex: /^https:\/\/.*\.vercel\.app$/ já está incluído
APP_URL=http://localhost:5173

# [OPCIONAL] Servir frontend estático junto com o backend.
#   → Usado em: server.ts (valida com NODE_ENV === 'production')
#   → Defina como 'true' em Railway/Render para servir o build do Vite
#   → Não necessário no Cloud Run + Vercel (cada um serve sua parte)
SERVE_STATIC=

# [OPCIONAL] Ambiente da aplicação. Afeta logs e detalhes de erro.
#   → Usado em: server.ts, src/lib/prisma.ts, src/lib/server-logger.ts
#   → 'development': logs detalhados, erros com stack trace
#   → 'production': logs mínimos, erros sem stack trace
NODE_ENV=development

# ──────────────────────────────────────────────────────────
# BANCO DE DADOS — PostgreSQL (Supabase)
# ──────────────────────────────────────────────────────────

# [OBRIGATÓRIO] URL completa de conexão PostgreSQL (usada pelo Prisma).
#   → Usado em: prisma.config.ts, scripts/refactor-prisma.ts
#   → Onde pegar: Dashboard do Supabase → Settings → Database → Connection string
#   → Formato: postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres
#   → ⚠️ Inclua ?sslmode=require no final se necessário
DATABASE_URL=

# [OBRIGATÓRIO] Host do banco PostgreSQL (validado no startup).
#   → Usado em: src/lib/prisma.ts (conexão via adapter)
#   → Onde pegar: Dashboard do Supabase → Settings → Database → Host
#   → Ex: db.xxxxx.supabase.co
DB_HOST=db.xxxxx.supabase.co

# [OPCIONAL] Porta do banco. Default: 5432.
#   → Usado em: src/lib/prisma.ts
DB_PORT=5432

# [OBRIGATÓRIO] Usuário do banco.
#   → Usado em: src/lib/prisma.ts
#   → Default Supabase: postgres
DB_USER=postgres

# [OBRIGATÓRIO] Senha do banco.
#   → Usado em: src/lib/prisma.ts
#   → Onde pegar: Dashboard do Supabase → Settings → Database → Database password
#   → ⚠️ Nunca commite a senha real! Em produção use Secret Manager.
DB_PASSWORD=sua-senha-aqui

# [OPCIONAL] Nome do banco. Default: postgres.
#   → Usado em: src/lib/prisma.ts
DB_NAME=postgres

# ──────────────────────────────────────────────────────────
# INTELIGÊNCIA ARTIFICIAL — Google Gemini
# ──────────────────────────────────────────────────────────

# [RECOMENDADO] Chave de API do Google Gemini para análise de OS.
#   → Usado em: src/routes/ai.ts
#   → Onde pegar: https://aistudio.google.com/apikey
#   → Sem essa chave, o endpoint /api/ai/generate retorna erro
GEMINI_API_KEY=

# ──────────────────────────────────────────────────────────
# SUPABASE — Edge Functions (Serverless)
# ──────────────────────────────────────────────────────────

# [RECOMENDADO] Chave de serviço (service_role) do Supabase para Edge Functions.
#   → Usado em: supabase/functions/_shared/database.ts, supabase/functions/login/index.ts
#   → Onde pegar: Dashboard do Supabase → Settings → API → service_role secret
#   → ⚠️ PERIGO: acesso total ao banco! Nunca exponha no frontend.
#   → No Cloud Run: configurado via Secret Manager (cloudbuild.yaml)
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────
# WHATSAPP — SendPulse (Integração futura)
# ──────────────────────────────────────────────────────────

# [OPCIONAL] Client ID da API SendPulse para WhatsApp.
#   → Onde pegar: https://sendpulse.com → Settings → API
#   → Atualmente NÃO usado no código ativo, apenas documentado
SENDPULSE_CLIENT_ID=

# [OPCIONAL] Client Secret da API SendPulse.
#   → Onde pegar: https://sendpulse.com → Settings → API
SENDPULSE_CLIENT_SECRET=

# [OPCIONAL] ID do template de mensagem WhatsApp no SendPulse.
#   → Onde pegar: SendPulse → WhatsApp → Templates
SENDPULSE_TEMPLATE_ID=