# Configurações do Vercel (Frontend - Vite)
# ==========================================
# URL pública do backend (Railway) - Exemplo: https://sua-api.up.railway.app
# Localmente, você pode usar: http://localhost:3000
VITE_API_URL=http://localhost:3000

# ==========================================
# Configurações do Railway / Local (Backend - Node.js)
# ==========================================
# Porta que o servidor backend vai rodar
PORT=3000

# Senha do administrador padrão (usada na primeira vez que iniciar o sistema)
ADMIN_PASSWORD=admin

# ==========================================
# Configurações do Banco de Dados (Supabase)
# ==========================================
# URL de conexão com o banco de dados (PostgreSQL do Supabase)
# Substitua a senha e o host de acordo com seu projeto Supabase
# Exemplo: postgresql://postgres:SuaSenhaAqui@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# ==========================================
# Configurações do Supabase (Opcional - se for usar Auth/Storage no futuro)
# ==========================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================
# Configurações da API WhatsApp (SendPulse - Opcional se for via banco de dados)
=======
# OBRIGATÓRIAS EM PRODUÇÃO
# ==========================================

# Segredo para assinar tokens JWT (gere com: openssl rand -hex 32)
JWT_SECRET=seu-segredo-aqui-minimo-32-caracteres

# Senha do administrador padrão (criada no primeiro boot)
ADMIN_PASSWORD=sua-senha-segura-aqui

# Chave da API Google Gemini — APENAS NO BACKEND, nunca exposta ao frontend
GEMINI_API_KEY=sua-chave-gemini-aqui

# URL base do app em produção (para CORS)
APP_URL=https://seu-app.onrender.com

# ==========================================
# OPCIONAIS
# ==========================================

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Caminho do banco SQLite (padrão: ./data/finance.db)
DB_PATH=./data/finance.db

# ==========================================
# SUPABASE (Standby — migração futura)
# ==========================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

