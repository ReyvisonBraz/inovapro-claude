# =========================================================
# INOVA PRO — Variáveis de Ambiente
# =========================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# Arquitetura:
#   Frontend (Vercel) → Backend (Cloud Run) → Banco (Supabase PostgreSQL)
# =========================================================

# ─── Frontend (Vite) ───
# URL pública do backend (Cloud Run após deploy)
# Local: http://localhost:3000 ou http://localhost:3001
VITE_API_URL=http://localhost:3000

# ─── Backend (Express) ───
# Porta do servidor (Cloud Run injeta PORT=8080 automaticamente)
PORT=3000

# Segredo para assinar JWT (gere com: openssl rand -hex 32)
JWT_SECRET=seu-segredo-aqui-minimo-32-caracteres

# URL base do app em produção (para CORS)
APP_URL=http://localhost:5173

# ─── Banco de Dados (Supabase PostgreSQL) ───
# Opção 1: URL de conexão completa
DATABASE_URL=

# Opção 2: Credenciais separadas (usado pelo Prisma adapter)
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_NAME=postgres

# ─── Google Gemini AI (Opcional) ───
GEMINI_API_KEY=

# ─── Supabase (Edge Functions / Auth futuro) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── SendPulse / WhatsApp (Opcional) ───
SENDPULSE_CLIENT_ID=
SENDPULSE_CLIENT_SECRET=
SENDPULSE_TEMPLATE_ID=

# ─── Ambiente ───
NODE_ENV=development
