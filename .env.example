# FinanceFlow OS - Environment Variables

# Server
PORT=3000

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# CORS (for mobile/external access)
CORS_ORIGIN=*

# Database (for future PostgreSQL migration)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Gemini AI (optional)
GEMINI_API_KEY=

# Vite HMR
DISABLE_HMR=false
